# ============================================================
# .gitignore — Honeypot FV con Detección por ML
# Universidad Santo Tomás — Ingeniería Electrónica
# ============================================================

# ------------------------------------------------------------
# DATOS CAPTURADOS — nunca versionar (pueden ser grandes y
# contener IPs reales de atacantes)
# ------------------------------------------------------------
datos/raw/
datos/procesados/
datos/etiquetados/
honeypot/capturas/cowrie/
honeypot/capturas/modbus/
honeypot/capturas/mqtt/
honeypot/capturas/pcap/

# Archivos de captura de red
*.pcap
*.pcap.gz
*.cap

# Bases de datos locales
*.db
*.sqlite
*.sqlite3
*.sqlite3-journal

# ------------------------------------------------------------
# MODELOS ML ENTRENADOS — archivos binarios grandes
# (versionar solo métricas y notebooks, no el .pkl)
# ------------------------------------------------------------
ml/modelos/*.pkl
ml/modelos/*.joblib
ml/modelos/*.h5
ml/modelos/*.pt

# ------------------------------------------------------------
# DATASETS EXTERNOS — descargar con el script, no versionar
# ------------------------------------------------------------
datos/externos/unsw_nb15/*.csv
datos/externos/unsw_nb15/*.zip
datos/externos/modbus_ics_frazao/*.csv
datos/externos/modbus_ics_frazao/*.zip

# ------------------------------------------------------------
# SECRETOS Y CONFIGURACIÓN LOCAL
# ------------------------------------------------------------
.env
.envrc
*.env.local
secrets/
honeypot/cowrie/userdb.txt

# ------------------------------------------------------------
# DOCUMENTO DE TESIS — PDFs compilados (se regeneran)
# ------------------------------------------------------------
tesis/pdf/*.pdf
tesis/latex/*.aux
tesis/latex/*.log
tesis/latex/*.out
tesis/latex/*.toc
tesis/latex/*.lof
tesis/latex/*.lot
tesis/latex/*.bbl
tesis/latex/*.blg
tesis/latex/*.fls
tesis/latex/*.fdb_latexmk
tesis/latex/*.synctex.gz

# ------------------------------------------------------------
# PYTHON
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
*.egg-info/
dist/
build/
.pytest_cache/
.coverage
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
tempCodeRunnerFile.py

# ------------------------------------------------------------
# JUPYTER
# ------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# ------------------------------------------------------------
# DOCKER
# ------------------------------------------------------------
# No ignorar docker-compose.yml — es parte del proyecto
# Ignorar solo datos de volúmenes locales si existieran
postgres_data/

# ------------------------------------------------------------
# SISTEMA OPERATIVO
# ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
*~
*.swp
*.swo

# ------------------------------------------------------------
# VS CODE — conservar settings.json (palabras del corrector)
# ignorar configuraciones de usuario locales
# ------------------------------------------------------------
.vscode/launch.json
.vscode/tasks.json
.vscode/*.code-workspace

# ------------------------------------------------------------
# STREAMLIT
# ------------------------------------------------------------
.streamlit/secrets.toml

# ------------------------------------------------------------
# LOGS GENERALES (fuera de las carpetas de capturas)
# ------------------------------------------------------------
*.log